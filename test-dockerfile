FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /build
RUN --mount=type=bind,source=src/ClaudeNest.Backend,target=/src/backend \
    --mount=type=bind,source=src/ClaudeNest.Shared,target=/src/shared \
    --mount=type=bind,source=src/ClaudeNest.ServiceDefaults,target=/src/defaults \
    cp -r /src/backend ClaudeNest.Backend && \
    cp -r /src/shared ClaudeNest.Shared && \
    cp -r /src/defaults ClaudeNest.ServiceDefaults && \
    dotnet publish ClaudeNest.Backend/ClaudeNest.Backend.csproj \
        -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 8080
ENV ASPNETCORE_HTTP_PORTS=8080
ENTRYPOINT ["dotnet", "ClaudeNest.Backend.dll"]
